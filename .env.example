# Database
DB_HOST=postgresql
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@postgresql:5432/postgres #"driver://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"

#APP
MOLECULES_TABLE=production_molecules

#SECURITY
API_KEY_HASHES=your_sha256_hash_here

#CORS
ALLOWED_ORIGINS=https://your-frontend-domain.com

#UVICORN
API_PORT=8000
LOG_LEVEL=info
UVICORN_WORKERS=4
BUILD_ENV=production
